<!DOCTYPE html>
<html lang="en" style="margin:0; padding:0;">
<head>
    <meta charset="UTF-8" />
    <title>PH Tour – Reset Your Password</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <style>
        :root {
            color-scheme: light dark;
        }

        /* Base styles (light default) */
        body {
            margin: 0;
            padding: 0;
            background-color: #eef2f7;
        }

        .email-body {
            background-color: #eef2f7;
        }

        .card {
            background-color: #ffffff;
            color: #0f172a;
        }

        .muted {
            color: #6b7280;
        }

        .divider {
            border-top: 1px solid #e5e7eb;
        }

        .brand-gradient {
            background: radial-gradient(circle at 0% 0%, #0ea5e9 0, #22c55e 40%, #0f172a 100%);
        }

        .btn-primary {
            background: linear-gradient(135deg, #0ea5e9, #22c55e);
            color: #ffffff !important;
        }

        .pill-badge {
            background: rgba(15, 23, 42, 0.1);
            color: #f9fafb;
        }

        /* Dark mode overrides */
        @media (prefers-color-scheme: dark) {
            body {
                background-color: #020617;
            }

            .email-body {
                background-color: #020617 !important;
            }

            .card {
                background-color: #020617 !important;
                color: #e5e7eb !important;
            }

            .muted {
                color: #9ca3af !important;
            }

            .divider {
                border-top: 1px solid #1f2933 !important;
            }

            .pill-badge {
                background: rgba(15, 23, 42, 0.8) !important;
                color: #e5e7eb !important;
            }

            .link-text {
                color: #38bdf8 !important;
            }
        }
    </style>
</head>

<body class="email-body"
      style="
      margin: 0;
      padding: 0;
      background-color: #eef2f7;
      font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text',
        'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    "
>
<table
        width="100%"
        border="0"
        cellspacing="0"
        cellpadding="0"
        style="padding: 32px 16px;"
        role="presentation"
>
    <tr>
        <td align="center">
            <!-- Outer max-width container -->
            <table
                    width="100%"
                    cellpadding="0"
                    cellspacing="0"
                    border="0"
                    style="max-width: 640px; width: 100%;"
                    role="presentation"
            >
                <!-- Brand / top area -->
                <tr>
                    <td style="padding-bottom: 16px;" align="center">
                        <div
                                style="
                    font-size: 11px;
                    letter-spacing: 0.18em;
                    text-transform: uppercase;
                    color: #9ca3af;
                  "
                        >
                            PH TOUR ACCOUNT SECURITY
                        </div>
                    </td>
                </tr>

                <!-- Main card -->
                <tr>
                    <td>
                        <table
                                width="100%"
                                cellpadding="0"
                                cellspacing="0"
                                border="0"
                                class="card"
                                style="
                    border-radius: 20px;
                    overflow: hidden;
                    background-color: #ffffff;
                    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
                  "
                                role="presentation"
                        >
                            <!-- Card top with gradient -->
                            <tr>
                                <td
                                        class="brand-gradient"
                                        style="
                        padding: 24px 24px 28px;
                        background: radial-gradient(
                          circle at 0% 0%,
                          #0ea5e9 0,
                          #22c55e 40%,
                          #0f172a 100%
                        );
                        color: #f9fafb;
                      "
                                >
                                    <table
                                            width="100%"
                                            cellpadding="0"
                                            cellspacing="0"
                                            border="0"
                                            role="presentation"
                                    >
                                        <tr>
                                            <td align="left" style="vertical-align: top;">
                                                <div
                                                        style="
                                font-size: 22px;
                                font-weight: 700;
                                letter-spacing: 0.12em;
                                text-transform: uppercase;
                              "
                                                >
                                                    PH TOUR
                                                </div>
                                                <div
                                                        style="
                                margin-top: 6px;
                                font-size: 12px;
                                opacity: 0.9;
                                letter-spacing: 0.12em;
                                text-transform: uppercase;
                              "
                                                >
                                                    Discover • Explore • Enjoy
                                                </div>
                                            </td>
                                            <td align="right" style="vertical-align: top;">
                                                <div
                                                        style="
                                display: inline-block;
                                padding: 6px 12px;
                                border-radius: 999px;
                                font-size: 11px;
                                text-transform: uppercase;
                                letter-spacing: 0.14em;
                                background: rgba(15, 23, 42, 0.22);
                                color: #e5e7eb;
                              "
                                                >
                                                    Password Reset
                                                </div>
                                            </td>
                                        </tr>

                                        <tr>
                                            <td colspan="2" style="padding-top: 18px;">
                                                <div
                                                        style="
                                font-size: 18px;
                                font-weight: 600;
                                margin-bottom: 4px;
                              "
                                                >
                                                    Hi <span><%= name %></span>,
                                                </div>
                                                <div
                                                        style="
                                font-size: 13px;
                                max-width: 380px;
                                line-height: 1.6;
                                opacity: 0.92;
                              "
                                                >
                                                    We received a request to reset the password for
                                                    your PH Tour account. Use the secure link below
                                                    to set a new password and continue planning your
                                                    next journey. ✈️
                                                </div>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>

                            <!-- Card content -->
                            <tr>
                                <td
                                        style="
                        padding: 22px 24px 8px;
                        font-size: 14px;
                        line-height: 1.7;
                        color: #0f172a;
                      "
                                >
                                    <p style="margin: 0 0 10px;">
                                        For your security, this reset link is:
                                    </p>

                                    <ul
                                            style="
                          margin: 0 0 16px 18px;
                          padding: 0;
                          color: #4b5563;
                          font-size: 13px;
                        "
                                    >
                                        <li>Unique to your PH Tour account</li>
                                        <li>
                                            Valid for a limited time or until it’s used once
                                        </li>
                                        <li>Only works if requested from this email address</li>
                                    </ul>

                                    <p class="muted" style="margin: 0 0 16px; font-size: 13px;">
                                        If you didn’t request a password reset, you can safely
                                        ignore this email—your password will remain unchanged.
                                    </p>
                                </td>
                            </tr>

                            <!-- Button -->
                            <tr>
                                <td align="center" style="padding: 4px 24px 18px;">
                                    <a
                                            href="<%= resetUILink %>"
                                            class="btn-primary"
                                            style="
                          display: inline-block;
                          padding: 12px 30px;
                          border-radius: 999px;
                          background: linear-gradient(135deg, #0ea5e9, #22c55e);
                          color: #ffffff;
                          font-size: 14px;
                          font-weight: 600;
                          text-decoration: none;
                          letter-spacing: 0.08em;
                          text-transform: uppercase;
                          box-shadow: 0 12px 25px rgba(34, 197, 94, 0.35);
                        "
                                    >
                                        Reset Password
                                    </a>
                                </td>
                            </tr>

                            <!-- URL fallback -->
                            <tr>
                                <td
                                        style="
                        padding: 0 24px 22px;
                        font-size: 12px;
                        line-height: 1.7;
                      "
                                >
                                    <p class="muted" style="margin: 0 0 6px;">
                                        If the button doesn’t work, copy and paste this link
                                        into your browser:
                                    </p>
                                    <p
                                            style="
                          margin: 0 0 14px;
                          word-break: break-all;
                          font-size: 12px;
                        "
                                    >
                                        <a
                                                href="<%= resetUILink %>"
                                                class="link-text"
                                                style="
                            color: #0ea5e9;
                            text-decoration: underline;
                            text-decoration-thickness: 1px;
                          "
                                        >
                                            <%= resetUILink %>
                                        </a>
                                    </p>
                                </td>
                            </tr>

                            <!-- Divider -->
                            <tr>
                                <td style="padding: 0 24px;">
                                    <hr
                                            class="divider"
                                            style="
                          border: none;
                          border-top: 1px solid #e5e7eb;
                          margin: 0 0 12px;
                        "
                                    />
                                </td>
                            </tr>

                            <!-- Security note & footer -->
                            <tr>
                                <td
                                        style="
                        padding: 0 24px 22px;
                        font-size: 12px;
                        line-height: 1.7;
                      "
                                >
                                    <table
                                            width="100%"
                                            cellpadding="0"
                                            cellspacing="0"
                                            border="0"
                                            role="presentation"
                                    >
                                        <tr>
                                            <td style="vertical-align: top; padding-right: 8px;">
                                                <div
                                                        class="pill-badge"
                                                        style="
                                display: inline-block;
                                padding: 4px 10px;
                                border-radius: 999px;
                                font-size: 11px;
                                text-transform: uppercase;
                                letter-spacing: 0.14em;
                                background: rgba(15, 23, 42, 0.06);
                              "
                                                >
                                                    Security tip
                                                </div>
                                                <p
                                                        class="muted"
                                                        style="margin: 8px 0 0; font-size: 11px;"
                                                >
                                                    Never share your password or reset link with
                                                    anyone. PH Tour will never ask you for your
                                                    password via email or message.
                                                </p>
                                            </td>
                                        </tr>
                                    </table>

                                    <p
                                            class="muted"
                                            style="margin: 16px 0 0; font-size: 11px;"
                                    >
                                        You’re receiving this email because a password reset
                                        was requested for your PH Tour account.
                                        If this wasn’t you, we recommend checking your account
                                        activity once you sign in again.
                                    </p>

                                    <p
                                            class="muted"
                                            style="margin: 10px 0 0; font-size: 11px;"
                                    >
                                        &copy; <%= new Date().getFullYear() %> PH Tour. All
                                        rights reserved.
                                    </p>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <!-- Tiny footer -->
                <tr>
                    <td align="center" style="padding-top: 16px;">
                        <p
                                style="
                    margin: 0;
                    font-size: 11px;
                    color: #9ca3af;
                    line-height: 1.6;
                  "
                        >
                            Sent with care by PH Tour – plan your next escape with us.
                        </p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>
