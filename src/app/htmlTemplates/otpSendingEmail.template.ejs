<!DOCTYPE html>
<html lang="en" style="margin:0; padding:0;">
<head>
    <meta charset="UTF-8" />
    <title>PH Tour – Your Verification Code</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <style>
        :root {
            color-scheme: light dark;
        }

        /* Base styles (light default) */
        body {
            margin: 0;
            padding: 0;
            background-color: #eef2f7;
        }

        .email-body {
            background-color: #eef2f7;
        }

        .card {
            background-color: #ffffff;
            color: #0f172a;
        }

        .muted {
            color: #6b7280;
        }

        .divider {
            border-top: 1px solid #e5e7eb;
        }

        .brand-gradient {
            background: radial-gradient(circle at 0% 0%, #0ea5e9 0, #22c55e 40%, #0f172a 100%);
        }

        .pill-badge {
            background: rgba(15, 23, 42, 0.06);
            color: #111827;
        }

        .otp-box {
            letter-spacing: 0.4em;
            font-weight: 700;
            font-size: 20px;
        }

        .label-chip {
            text-transform: uppercase;
            letter-spacing: 0.16em;
            font-size: 10px;
            padding: 3px 8px;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.7);
        }

        .mono {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
            "Liberation Mono", "Courier New", monospace;
        }

        /* Dark mode overrides */
        @media (prefers-color-scheme: dark) {
            body {
                background-color: #020617;
            }

            .email-body {
                background-color: #020617 !important;
            }

            .card {
                background-color: #020617 !important;
                color: #e5e7eb !important;
            }

            .muted {
                color: #9ca3af !important;
            }

            .divider {
                border-top: 1px solid #1f2933 !important;
            }

            .pill-badge {
                background: rgba(15, 23, 42, 0.8) !important;
                color: #e5e7eb !important;
            }

            .label-chip {
                border-color: rgba(148, 163, 184, 0.8);
                color: #e5e7eb;
            }

            .link-text {
                color: #38bdf8 !important;
            }
        }
    </style>
</head>

<body class="email-body"
      style="
      margin: 0;
      padding: 0;
      background-color: #eef2f7;
      font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text',
        'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    "
>
<table
        width="100%"
        border="0"
        cellspacing="0"
        cellpadding="0"
        style="padding: 32px 16px;"
        role="presentation"
>
    <tr>
        <td align="center">
            <!-- Outer max-width container -->
            <table
                    width="100%"
                    cellpadding="0"
                    cellspacing="0"
                    border="0"
                    style="max-width: 640px; width: 100%;"
                    role="presentation"
            >
                <!-- Brand / top label -->
                <tr>
                    <td style="padding-bottom: 16px;" align="center">
                        <div
                                style="
                    font-size: 11px;
                    letter-spacing: 0.18em;
                    text-transform: uppercase;
                    color: #9ca3af;
                  "
                        >
                            PH TOUR ACCOUNT VERIFICATION
                        </div>
                    </td>
                </tr>

                <!-- Main card -->
                <tr>
                    <td>
                        <table
                                width="100%"
                                cellpadding="0"
                                cellspacing="0"
                                border="0"
                                class="card"
                                style="
                    border-radius: 20px;
                    overflow: hidden;
                    background-color: #ffffff;
                    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
                  "
                                role="presentation"
                        >
                            <!-- Card top with gradient -->
                            <tr>
                                <td
                                        class="brand-gradient"
                                        style="
                        padding: 24px 24px 26px;
                        background: radial-gradient(
                          circle at 0% 0%,
                          #0ea5e9 0,
                          #22c55e 40%,
                          #0f172a 100%
                        );
                        color: #f9fafb;
                      "
                                >
                                    <table
                                            width="100%"
                                            cellpadding="0"
                                            cellspacing="0"
                                            border="0"
                                            role="presentation"
                                    >
                                        <tr>
                                            <td align="left" style="vertical-align: top;">
                                                <div
                                                        style="
                                font-size: 22px;
                                font-weight: 700;
                                letter-spacing: 0.12em;
                                text-transform: uppercase;
                              "
                                                >
                                                    PH TOUR
                                                </div>
                                                <div
                                                        style="
                                margin-top: 6px;
                                font-size: 12px;
                                opacity: 0.9;
                                letter-spacing: 0.12em;
                                text-transform: uppercase;
                              "
                                                >
                                                    Discover • Explore • Enjoy
                                                </div>
                                            </td>
                                            <td align="right" style="vertical-align: top;">
                                                <div
                                                        style="
                                display: inline-block;
                                padding: 6px 12px;
                                border-radius: 999px;
                                font-size: 11px;
                                text-transform: uppercase;
                                letter-spacing: 0.14em;
                                background: rgba(15, 23, 42, 0.22);
                                color: #e5e7eb;
                              "
                                                >
                                                    One-Time Passcode
                                                </div>
                                            </td>
                                        </tr>

                                        <tr>
                                            <td colspan="2" style="padding-top: 18px;">
                                                <div
                                                        style="
                                font-size: 18px;
                                font-weight: 600;
                                margin-bottom: 4px;
                              "
                                                >
                                                    Hi <span><%= name %></span>,
                                                </div>
                                                <div
                                                        style="
                                font-size: 13px;
                                max-width: 400px;
                                line-height: 1.6;
                                opacity: 0.92;
                              "
                                                >
                                                    To verify your email address and continue with
                                                    your PH Tour experience, use the one-time
                                                    passcode below. This helps us keep your account
                                                    secure while you plan your next gateway. 🌍
                                                </div>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>

                            <!-- Card content -->
                            <tr>
                                <td
                                        style="
                        padding: 20px 24px 10px;
                        font-size: 14px;
                        line-height: 1.7;
                        color: #0f172a;
                      "
                                >
                                    <table
                                            width="100%"
                                            cellpadding="0"
                                            cellspacing="0"
                                            border="0"
                                            role="presentation"
                                    >
                                        <tr>
                                            <td style="vertical-align: top;">
                                                <p style="margin: 0 0 10px;">
                                                    We’re verifying this email:
                                                </p>

                                                <div
                                                        style="
                                display: inline-flex;
                                align-items: center;
                                padding: 6px 10px;
                                border-radius: 999px;
                                border: 1px dashed rgba(148, 163, 184, 0.8);
                                font-size: 12px;
                                margin-bottom: 18px;
                              "
                                                >
                              <span class="label-chip mono"
                                    style="margin-right: 8px;"
                              >
                                EMAIL
                              </span>
                                                    <span class="mono">
                                <%= email %>
                              </span>
                                                </div>

                                                <p class="muted" style="margin: 0 0 10px; font-size: 13px;">
                                                    Enter this code on the PH Tour screen to continue:
                                                </p>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>

                            <!-- OTP block -->
                            <tr>
                                <td align="center" style="padding: 4px 24px 18px;">
                                    <table
                                            cellpadding="0"
                                            cellspacing="0"
                                            border="0"
                                            role="presentation"
                                            style="
                          padding: 14px 14px;
                          border-radius: 16px;
                          border: 1px solid rgba(148, 163, 184, 0.7);
                          background: rgba(248, 250, 252, 0.8);
                        "
                                    >
                                        <tr>
                                            <td align="center">
                                                <div
                                                        class="otp-box mono"
                                                        style="
                                font-size: 22px;
                                font-weight: 700;
                                letter-spacing: 0.45em;
                                padding: 4px 2px 2px;
                              "
                                                >
                                                    <%= otp %>
                                                </div>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td align="center" style="padding-top: 6px;">
                                                <div
                                                        class="muted"
                                                        style="font-size: 11px; line-height: 1.6;"
                                                >
                                                    This one-time passcode will expire in
                                                    <strong><%= expiryTime %></strong>.
                                                </div>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>

                            <!-- Info + security -->
                            <tr>
                                <td
                                        style="
                        padding: 0 24px 20px;
                        font-size: 12px;
                        line-height: 1.7;
                      "
                                >
                                    <p class="muted" style="margin: 0 0 8px;">
                                        For your security, this code:
                                    </p>
                                    <ul
                                            style="
                          margin: 0 0 14px 18px;
                          padding: 0;
                          color: #4b5563;
                          font-size: 12px;
                        "
                                    >
                                        <li>Can only be used once</li>
                                        <li>Works only on the device/browser where it was requested</li>
                                        <li>Should never be shared with anyone</li>
                                    </ul>

                                    <div
                                            class="pill-badge"
                                            style="
                          display: inline-block;
                          padding: 4px 10px;
                          border-radius: 999px;
                          font-size: 11px;
                          text-transform: uppercase;
                          letter-spacing: 0.14em;
                          background: rgba(15, 23, 42, 0.06);
                        "
                                    >
                                        Security tip
                                    </div>

                                    <p class="muted" style="margin: 8px 0 0; font-size: 11px;">
                                        PH Tour will never ask you to share your one-time
                                        passcode in chat, over the phone, or via any other
                                        message. If you didn’t request this code, you can ignore
                                        this email.
                                    </p>
                                </td>
                            </tr>

                            <!-- Divider -->
                            <tr>
                                <td style="padding: 0 24px;">
                                    <hr
                                            class="divider"
                                            style="
                          border: none;
                          border-top: 1px solid #e5e7eb;
                          margin: 0 0 12px;
                        "
                                    />
                                </td>
                            </tr>

                            <!-- Footer -->
                            <tr>
                                <td
                                        style="
                        padding: 0 24px 22px;
                        font-size: 11px;
                        line-height: 1.7;
                      "
                                >
                                    <p class="muted" style="margin: 0 0 6px;">
                                        You’re receiving this email because someone tried to
                                        sign in or verify an account on PH Tour using this
                                        address: <span class="mono"><%= email %></span>.
                                    </p>
                                    <p class="muted" style="margin: 0 0 8px;">
                                        If this wasn’t you, you can safely ignore this email.
                                        Your account and password will remain unchanged.
                                    </p>
                                    <p class="muted" style="margin: 6px 0 0;">
                                        &copy; <%= new Date().getFullYear() %> PH Tour. All
                                        rights reserved.
                                    </p>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <!-- Tiny footer -->
                <tr>
                    <td align="center" style="padding-top: 16px;">
                        <p
                                style="
                    margin: 0;
                    font-size: 11px;
                    color: #9ca3af;
                    line-height: 1.6;
                  "
                        >
                            Sent by PH Tour – secure verification for your next adventure.
                        </p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>
